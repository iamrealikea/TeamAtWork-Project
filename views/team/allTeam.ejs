<%- include("../partials/header") %>
  <%- include("../partials/navigation") %>

<link rel="stylesheet" href="/css/team.css">

    <div class="header-with-icon">
      <div id="header-info">
        <img src="/icon/team.svg" alt="Team Icon" class="header-icon">
        <h1>Your Team</h1>
      </div>
      <div id="header-btn">
        <button class="btn" id="create-team-btn"><a href="/team/create">Create Team</a></button>
      </div>
    </div>
      <div class="toolbar">

        <input type="text" id="searchInput" placeholder="Search team..." />

        <div class="filter-wrapper">
          <button id="filterBtn" class="filter-btn">
            Filter ▾
          </button>

          <div id="filterMenu" class="filter-menu hidden">
            <div data-filter="">All</div>
            <div data-filter="small">1-3 Members</div>
            <div data-filter="medium">4-5 Members</div>
            <div data-filter="large">6+ Members</div>
          </div>
        </div>

      </div>

      <div class="team-container">
        <div class="team-list">

          <% teams.forEach(team=> { %>
            <a href="/team/<%= team.id %>" class="team-card" data-name="<%= team.name.toLowerCase() %>"
              data-count="<%= team.member_count %>">
              <div>
                <h2><%= team.name %></h2>
                <p>Created: <%= team.creator_name %></p>
              </div> 
              <div class="member">
              <p><%= team.member_count %> Members</p>
              <div id="team-members">
              <% 
                const members = teamMemberMap[team.id] || [];
                const maxVisibleMembers = 3;
                const visibleMembers = members.slice(0, maxVisibleMembers);
                const overflowMembers = members.length - visibleMembers.length;
                %>
              <% visibleMembers.forEach(member => { 
              const avatarSrc = (member.avatar_hash && member.avatar_ext)
                  ? `/uploads/profiles/${member.avatar_hash}${member.avatar_ext}`
                  : '/default-avatar.png';
              %>
              
              <img src="<%= avatarSrc %>" id="mini-avatar">
            <% }) %>
            <% if (overflowMembers > 0) { %>
                <span class="member-overflow">+<%= overflowMembers %></span>
                
            <% } %>
            </div>
              </div>
            <% }) %>
            </a>
      </div>
      </div>
    </section>

    <script>
      document.addEventListener("DOMContentLoaded", () => {

        const searchInput = document.getElementById('searchInput');
        const filterBtn = document.getElementById('filterBtn');
        const filterMenu = document.getElementById('filterMenu');
        const options = filterMenu.querySelectorAll('div');
        const cards = document.querySelectorAll('.team-card');

        let currentFilter = "";

        filterBtn.addEventListener('click', () => {
          filterMenu.classList.toggle('hidden');
        });

        // filter
        options.forEach(opt => {
          opt.addEventListener('click', () => {
            currentFilter = opt.dataset.filter;
            filterBtn.textContent = opt.textContent + " ▾";
            filterMenu.classList.add('hidden');
            applyFilter();
          });
        });

        // search
        searchInput.addEventListener('input', applyFilter);

        function applyFilter() {
          const search = searchInput.value.toLowerCase();

          cards.forEach(card => {
            const name = card.dataset.name;
            const count = Number.parseInt(card.dataset.count, 10) || 0;

            let matchSearch = name.includes(search);
            let matchFilter = true;

            if (currentFilter === "small") matchFilter = count <= 3;
            if (currentFilter === "medium") matchFilter = count >= 4 && count <= 5;
            if (currentFilter === "large") matchFilter = count >= 6;

            card.style.display = (matchSearch && matchFilter) ? "flex" : "none";
          });
        }

        document.addEventListener('click', (e) => {
          if (!filterBtn.contains(e.target) && !filterMenu.contains(e.target)) {
            filterMenu.classList.add('hidden');
          }
        });

      });
    </script>

    <%- include("../partials/footer") %>